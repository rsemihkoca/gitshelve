{
  "name": "gitstash",
  "displayName": "Git Shelve — IntelliJ-style stash",
  "description": "IntelliJ-style shelve for Git. A stash alternative that stores uncommitted changes as patches and shows them under the Source Control panel.",
  "version": "0.0.1",
  "publisher": "rsemihkoca",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers"],
  "keywords": ["shelve", "stash", "git stash", "intellij", "shelf", "patch", "source control", "scm"],
  "repository": {
    "type": "git",
    "url": "https://github.com/rsemihkoca/gitstash.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "scm": [
        {
          "id": "gitstashShelves",
          "name": "Shelf",
          "icon": "$(archive)"
        }
      ]
    },
    "commands": [
      { "command": "gitstash.shelve", "title": "Shelve Changes", "icon": "$(archive)" },
      { "command": "gitstash.unshelve", "title": "Unshelve", "icon": "$(arrow-down)" },
      { "command": "gitstash.delete", "title": "Delete Shelf", "icon": "$(trash)" },
      { "command": "gitstash.diff", "title": "View Diff" },
      { "command": "gitstash.refresh", "title": "Refresh", "icon": "$(refresh)" }
    ],
    "menus": {
      "view/title": [
        { "command": "gitstash.shelve", "when": "view == gitstashShelves", "group": "navigation@1" },
        { "command": "gitstash.refresh", "when": "view == gitstashShelves", "group": "navigation@2" }
      ],
      "view/item/context": [
        { "command": "gitstash.unshelve", "when": "view == gitstashShelves && viewItem == shelf", "group": "inline@1" },
        { "command": "gitstash.delete", "when": "view == gitstashShelves && viewItem == shelf", "group": "inline@2" },
        { "command": "gitstash.unshelve", "when": "view == gitstashShelves && viewItem == shelf", "group": "1_actions@1" },
        { "command": "gitstash.diff", "when": "view == gitstashShelves && viewItem == shelf", "group": "1_actions@2" },
        { "command": "gitstash.delete", "when": "view == gitstashShelves && viewItem == shelf", "group": "9_danger@1" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
